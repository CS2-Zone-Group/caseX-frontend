# Environment Configuration for CaseX Frontend
# Choose one configuration below based on your needs

# ===========================================
# LOCAL DEVELOPMENT (for developers)
# ===========================================
# Use this when running backend locally on your machine
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# PRODUCTION SERVER (for team collaboration)
# ===========================================
# Use this when connecting to the deployed backend server
# Uncomment these lines and comment out the local development lines above
# NEXT_PUBLIC_API_URL=https://api.casex.uz/api
# NEXT_PUBLIC_SITE_URL=https://casex.uz

# ===========================================
# INSTRUCTIONS
# ===========================================
# 1. For LOCAL development:
#    - Keep the localhost URLs uncommented
#    - Make sure your backend is running on localhost:4000
#
# 2. For TEAM collaboration (using server backend):
#    - Comment out the localhost URLs (add # at the beginning)
#    - Uncomment the production URLs (remove # from the beginning)
#    - Your frontend will connect to the deployed backend
#
# 3. Copy this file to .env.local and modify as needed:
#    cp .env.example .env.local
